# Nib runtime config
# Required for `nib "<prompt>"`
ANTHROPIC_API_KEY=sk-ant-...

# Optional: route API calls through a proxy / Bedrock-compatible gateway
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/v1

# Per-role model overrides (defaults shown).
# Roles:
#   main             — chat / tool-use (active model)
#   reasoning        — deep planning / thinking
#   default-haiku    — cheap routing / lightweight tasks
#   default-sonnet   — default mid-tier
#   default-opus     — default heavy-tier
# NIB_MODEL_MAIN=claude-sonnet-4-5
# NIB_MODEL_REASONING=claude-opus-4-5
# NIB_MODEL_DEFAULT_HAIKU=claude-haiku-4-5
# NIB_MODEL_DEFAULT_SONNET=claude-sonnet-4-5
# NIB_MODEL_DEFAULT_OPUS=claude-opus-4-5
