# Nib runtime config
# Required for `nib "<prompt>"`
ANTHROPIC_API_KEY=sk-ant-...

# Optional: route API calls through a proxy / Bedrock-compatible gateway
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/v1

# Per-role model overrides. Roles are picked per-task (e.g. by a skill's
# `model: haiku` metadata); unspecified callers use the 'main' role.
# Defaults shown.
# NIB_MODEL_MAIN=claude-sonnet-4-5
# NIB_MODEL_REASONING=claude-opus-4-5
# NIB_MODEL_HAIKU=claude-haiku-4-5
# NIB_MODEL_SONNET=claude-sonnet-4-5
# NIB_MODEL_OPUS=claude-opus-4-5
